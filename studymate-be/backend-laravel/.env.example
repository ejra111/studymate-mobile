APP_NAME=StudyMate
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:4000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Laragon/MySQL local default. Jika HeidiSQL login tanpa password, biarkan DB_PASSWORD kosong.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=studymate
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@studymate.local"
MAIL_FROM_NAME="${APP_NAME}"

# Isi dengan API key dari Groq Console jika ingin jawaban AI asli.
# Jika kosong, AI Coach tetap berjalan memakai fallback lokal.
GROQ_API_KEY= 
GROQ_MODEL=llama-3.3-70b-versatile

FRONTEND_URL=http://localhost:5173
VITE_APP_NAME="${APP_NAME}"
